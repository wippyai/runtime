{
	"servers": {
		"my-server-1": {
			"type": "http",
			"address": "127.0.0.1:8888",
			"app": [
				"my-app-1"
			],
			"tls": {},
			"cors": {}
		},
		"temporal": {}
	},
	"apps": {
		"my-app-1": {
			"source_code": "",
			"extensions": {
				"lua": [
					"http"
				]
			},
			"ext-config": {
				"env": {
					"key": "value"
				}
			},
			"paths": [
				"/v1/app"
			],
			"allowed_methods": "GET,POST",
			"pipeline": [
				{
					"name": "validate"
				},
				{
					"name": "auth",
					"runtime": "lua"
				}
			]
		}
	}
}
